{
  "name": "el-salvador-rutas-perdidas",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit:changed": "vitest run --changed --passWithNoTests",
    "test:unit:branch": "vitest run --changed origin/main --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "npm run build && node scripts/testing/run-focused-e2e.mjs smoke",
    "test:e2e:camera": "npm run build && node scripts/testing/run-focused-e2e.mjs camera",
    "test:e2e:map": "npm run build && node scripts/testing/run-focused-e2e.mjs map",
    "test:e2e:last-failed": "npm run build && node scripts/testing/run-focused-e2e.mjs last-failed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:models": "node scripts/models/generate-models.mjs",
    "generate:audio": "node scripts/audio/generate-audio.mjs",
    "generate:icons": "node scripts/assets/generate-pwa-icons.mjs",
    "capture:driving-ux": "node scripts/visual/capture-driving-ux.mjs",
    "capture:arcade-five-minutes": "node scripts/visual/capture-arcade-five-minutes.mjs",
    "download:roads": "sh scripts/roads/download-source.sh",
    "build:roads": "node scripts/roads/build-road-network.mjs",
    "check:roads": "node scripts/roads/validate-road-network.mjs",
    "check:mission-objectives": "node scripts/roads/validate-mission-objectives.mjs",
    "sync:map-assets": "node scripts/sync-map-assets.mjs",
    "check:external-resources": "node scripts/check-external-resources.mjs",
    "check:map": "node scripts/maps/validate-map.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run check:external-resources && npm run check:map && npm run check:roads && npm run check:mission-objectives && npm run build",
    "check:fast": "npm run typecheck && npm run test:unit:changed && npm run test:e2e:smoke",
    "check:branch": "npm run lint && npm run typecheck && npm run test:unit:branch && npm run test:e2e:smoke",
    "check:release": "npm run check && npm run test:e2e"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "5.2.10",
    "@turf/distance": "7.3.5",
    "@turf/helpers": "7.3.5",
    "maplibre-gl": "5.24.0",
    "pmtiles": "4.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "smp-noto-glyphs": "0.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
